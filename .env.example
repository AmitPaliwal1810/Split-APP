# Firebase Configuration
# Get these values from your Firebase Console > Project Settings
FIREBASE_API_KEY=your_api_key_here
FIREBASE_AUTH_DOMAIN=your_project_id.firebaseapp.com
FIREBASE_PROJECT_ID=your_project_id
FIREBASE_STORAGE_BUCKET=your_project_id.appspot.com
FIREBASE_MESSAGING_SENDER_ID=your_sender_id
FIREBASE_APP_ID=your_app_id
FIREBASE_DATABASE_URL=https://your_project_id-default-rtdb.firebaseio.com

# Google Sign-In
# Get this from Firebase Console > Authentication > Sign-in method > Google > Web SDK configuration
GOOGLE_WEB_CLIENT_ID=your_google_client_id.apps.googleusercontent.com

# App Configuration
APP_STORE_LINK=https://play.google.com/store/apps/details?id=your.package.name
APP_DOWNLOAD_MESSAGE=Hey! I'm using SplitBills to manage group expenses. Join me! Download the app here:

# Environment
NODE_ENV=development
